# ========================================
# AMBIENTE DE DESENVOLVIMENTO
# ========================================

# Database (PostgreSQL em Docker)
DATABASE_URI=postgres://postgres:postgres@db:5432/storge_care
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=storge_care

# Payload CMS
PAYLOAD_SECRET=YOUR_SECRET_HERE_CHANGE_IN_PRODUCTION

# Next.js
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Node Environment
NODE_ENV=development

# ========================================
# AMBIENTE DE PRODUÇÃO (.env.production)
# ========================================
# Copie este arquivo para .env.production e ajuste os valores

# Database (Produção - use senhas fortes!)
# DATABASE_URI=postgres://usuario:senha@host:5432/database
# POSTGRES_USER=prod_user
# POSTGRES_PASSWORD=senha_muito_segura_aqui
# POSTGRES_DB=storge_care_prod

# Payload CMS (Produção - gere um segredo único!)
# PAYLOAD_SECRET=gera_um_segredo_unico_e_longo_aqui

# Next.js (Produção - domínio real!)
# NEXT_PUBLIC_SERVER_URL=https://seu-dominio.com.br

# Node Environment
# NODE_ENV=production

# Google Analytics / Tag Manager
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=AW-17990509984

# Porta (opcional, padrão 3000)
# PORT=3000
